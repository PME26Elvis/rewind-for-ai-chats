{
  "name": "rewind-for-ai-chats",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @rewind/web",
    "dev:desktop": "npm run dev --workspace @rewind/desktop",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace @rewind/web",
    "build:desktop": "npm run build --workspace @rewind/desktop",
    "test": "node --test",
    "lint": "node scripts/lint.mjs",
    "format": "node -e \"console.log('No formatter configured for the zero-dependency scaffold.')\"",
    "db:migrate": "npm run db:migrate --workspace @rewind/db"
  },
  "type": "module",
  "dependencies": {
    "echarts-wordcloud": "^2.1.0"
  }
}
